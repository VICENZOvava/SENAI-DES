// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "mysql"
}

model Carros {
  id        Int     @id @default(autoincrement())
  placa String 
  marca String
  modelo String
  ano Int
}

model Cliente {
  id        Int     @id @default(autoincrement())
  nome String
  CPF String
  Email String
  CNH String
}